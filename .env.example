APP_NAME=ApplyForge Backend
ENV=dev
SECRET_KEY=change-this
ACCESS_TOKEN_EXP_MINUTES=30
REFRESH_TOKEN_EXP_DAYS=14
JWT_ALGORITHM=HS256
DATABASE_URL=mysql://user:password@hostname:3306/dbname
CORS_ORIGINS=http://localhost:3000

# Runtime providers (production-safe defaults)
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
AI_API_KEY=
OPENAI_BASE_URL=
AI_REQUEST_TIMEOUT_SECONDS=30
AI_MAX_RETRIES=2
AI_RETRY_BACKOFF_SECONDS=0.5

# Keep false in production. Set true only for local/dev tests where mock providers are required.
AI_ALLOW_MOCK_PROVIDERS=false

# Google OAuth (optional) — enables "Continue with Google" on login/register
# Get these from https://console.cloud.google.com/ → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

S3_ENDPOINT_URL=hjfhhc
S3_ACCESS_KEY=admin
S3_SECRET_KEY=your_s3_secret_key
S3_BUCKET=applyforge-uploads
S3_REGION=us-east-1
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Qdrant vector store — used by RAGService for efficient similarity search
# Self-hosted: QDRANT_URL=http://localhost:6333
# Qdrant Cloud: QDRANT_URL=https://<cluster-id>.us-east4-0.gcp.cloud.qdrant.io
QDRANT_URL=fsadfasdfas
QDRANT_API_KEY=fsadfsda
QDRANT_COLLECTION=applyforge_chunks
# Must match your embedding model output dimension:
#   text-embedding-3-small / ada-002 → 1536
#   text-embedding-3-large           → 3072
#   MockEmbeddingProvider (dev/test) → 16
EMBEDDING_DIM=1536
